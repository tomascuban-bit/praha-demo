# Copy this to .env and fill in your values for local development
# DO NOT commit .env to git

# Keboola credentials (from your Keboola project settings)
KBC_TOKEN=your-keboola-storage-token
KBC_URL=https://connection.europe-west3.gcp.keboola.com

# KAI agent token (usually same as KBC_TOKEN)
KAI_TOKEN=
